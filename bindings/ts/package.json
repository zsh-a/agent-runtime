{
  "name": "@agent-runtime/client",
  "version": "0.1.0",
  "description": "TypeScript bindings for the Agent Runtime JSON contracts.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
