{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naviwealth.local/schemas/agent-runtime/agent-spec.schema.json",
  "title": "AgentSpec",
  "type": "object",
  "required": ["protocol_version", "id", "name", "version", "schedule"],
  "properties": {
    "protocol_version": { "const": "agent.v1" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "version": { "type": "string", "minLength": 1 },
    "schedule": { "$ref": "#/$defs/schedule" },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "metadata": {
      "type": "object",
      "default": {}
    }
  },
  "additionalProperties": true,
  "$defs": {
    "schedule": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "manual" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "every_seconds"],
          "properties": {
            "type": { "const": "interval" },
            "every_seconds": { "type": "integer", "minimum": 1 },
            "preferred_hour_local": {
              "type": ["integer", "null"],
              "minimum": 0,
              "maximum": 23
            },
            "jitter_seconds": {
              "type": ["integer", "null"],
              "minimum": 0
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
