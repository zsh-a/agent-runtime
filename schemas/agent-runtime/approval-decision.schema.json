{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naviwealth.local/schemas/agent-runtime/approval-decision.schema.json",
  "title": "ApprovalDecision",
  "type": "object",
  "required": [
    "protocol_version",
    "proposal_id",
    "decision",
    "decided_at"
  ],
  "properties": {
    "protocol_version": { "const": "agent.v1" },
    "proposal_id": { "type": "string", "minLength": 1 },
    "decision": {
      "type": "string",
      "enum": ["approve", "deny"]
    },
    "decided_at": { "type": "string", "format": "date-time" },
    "comment": { "type": "string" }
  },
  "additionalProperties": false
}
