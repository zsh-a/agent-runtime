{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naviwealth.local/schemas/agent-runtime/debug-bundle-manifest.schema.json",
  "title": "DebugBundleManifest",
  "type": "object",
  "required": [
    "bundle_version",
    "protocol_version",
    "runtime_version",
    "run_id",
    "agent_id",
    "created_at",
    "files"
  ],
  "properties": {
    "bundle_version": { "const": "debug_bundle.v1" },
    "protocol_version": { "const": "agent.v1" },
    "runtime_version": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "agent_version": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "files": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
