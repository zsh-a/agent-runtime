{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naviwealth.local/schemas/agent-runtime/llm-request.schema.json",
  "title": "LlmRequest",
  "type": "object",
  "required": ["protocol_version", "provider", "model", "messages"],
  "properties": {
    "protocol_version": { "const": "agent.v1" },
    "provider": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant", "tool"]
          },
          "content": { "type": "string" },
          "name": { "type": "string" },
          "metadata": { "type": "object", "default": {} }
        },
        "additionalProperties": false
      }
    },
    "temperature": { "type": ["number", "null"], "minimum": 0 },
    "max_output_tokens": { "type": ["integer", "null"], "minimum": 1 },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "input_schema", "risk"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "input_schema": { "type": "object" },
          "output_schema": { "type": ["object", "null"] },
          "risk": {
            "type": "string",
            "enum": ["read_only", "low", "medium", "high"]
          },
          "metadata": { "type": "object", "default": {} }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "metadata": { "type": "object", "default": {} }
  },
  "additionalProperties": false
}
