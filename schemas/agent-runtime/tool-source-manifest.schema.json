{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naviwealth.local/schemas/agent-runtime/tool-source-manifest.schema.json",
  "title": "ToolSourceManifest",
  "type": "object",
  "required": ["sources"],
  "properties": {
    "version": { "const": "tool_source.v1" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "tools"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "protocol": {
            "type": "string",
            "enum": ["jsonl_tool_call", "mcp_stdio", "http_json"],
            "default": "jsonl_tool_call"
          },
          "command": { "type": "string", "minLength": 1 },
          "args": {
            "type": "array",
            "items": { "type": "string" }
          },
          "endpoint": {
            "type": "string",
            "format": "uri",
            "pattern": "^https?://"
          },
          "headers": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "description", "input_schema", "risk"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "input_schema": { "type": "object" },
                "output_schema": { "type": ["object", "null"] },
                "risk": {
                  "type": "string",
                  "enum": ["read_only", "low", "medium", "high"]
                },
                "metadata": { "type": "object" }
              },
              "additionalProperties": false
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "protocol": { "const": "http_json" } },
              "required": ["protocol"]
            },
            "then": { "required": ["endpoint"] },
            "else": { "required": ["command"] }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
