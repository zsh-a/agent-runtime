{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/approval-decision.schema.json",
  "title": "ApprovalDecision",
  "type": "object",
  "required": [
    "protocol_version",
    "proposal_id",
    "decision",
    "decided_at"
  ],
  "properties": {
    "protocol_version": { "const": "agent.v1" },
    "proposal_id": { "type": "string", "minLength": 1 },
    "decision": {
      "type": "string",
      "enum": ["approve", "deny"]
    },
    "approval_level": {
      "type": "string",
      "enum": ["none", "single_user", "multi_approver", "admin"],
      "default": "single_user"
    },
    "decided_by": { "type": ["string", "null"], "minLength": 1 },
    "decided_at": { "type": "string", "format": "date-time" },
    "comment": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
