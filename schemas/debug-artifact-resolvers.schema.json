{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/debug-artifact-resolvers.schema.json",
  "title": "DebugArtifactResolvers",
  "type": "object",
  "required": ["protocol_version", "resolvers"],
  "properties": {
    "protocol_version": { "const": "agent.v1" },
    "resolvers": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_store_resolver" },
      "uniqueItems": true
    }
  },
  "$defs": {
    "artifact_store_resolver": {
      "type": "object",
      "required": ["provider", "root"],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "root": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
