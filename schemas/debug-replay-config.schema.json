{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/debug-replay-config.schema.json",
  "title": "DebugReplayConfig",
  "type": "object",
  "required": [
    "protocol_version",
    "runtime_version",
    "run_id",
    "agent_id",
    "replay_mode",
    "source_store",
    "timeout_seconds",
    "assets",
    "replay_command",
    "run_request"
  ],
  "properties": {
    "protocol_version": { "const": "agent.v1" },
    "runtime_version": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "pattern": "^run_" },
    "agent_id": { "type": "string", "minLength": 1 },
    "replay_mode": { "const": "trace_execute" },
    "source_store": { "type": "string", "minLength": 1 },
    "source_trace": { "type": "string", "minLength": 1 },
    "catalog": { "type": "string", "minLength": 1 },
    "timeout_seconds": { "type": "integer", "minimum": 1 },
    "assets": {
      "type": "object",
      "required": ["run_request", "trace"],
      "properties": {
        "run_request": { "const": "run_request.json" },
        "trace": { "const": "trace.json" },
        "events": { "const": "events.jsonl" },
        "tool_calls": { "const": "tool_calls.jsonl" },
        "state_snapshot": { "const": "state_snapshot.json" },
        "prompt_manifest": { "const": "prompt_manifest.json" }
      },
      "additionalProperties": false
    },
    "replay_command": {
      "type": "array",
      "minItems": 4,
      "items": { "type": "string" }
    },
    "run_request": { "type": "object" }
  },
  "additionalProperties": false
}
