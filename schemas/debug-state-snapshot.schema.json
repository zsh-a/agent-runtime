{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/debug-state-snapshot.schema.json",
  "title": "DebugStateSnapshot",
  "type": "object",
  "required": [
    "protocol_version",
    "runtime_version",
    "captured_at",
    "store_root",
    "run_id",
    "agent_id",
    "run_status",
    "steps",
    "proposals"
  ],
  "properties": {
    "protocol_version": { "const": "agent.v1" },
    "runtime_version": { "type": "string", "minLength": 1 },
    "captured_at": { "type": "string", "format": "date-time" },
    "store_root": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "pattern": "^run_" },
    "agent_id": { "type": "string", "minLength": 1 },
    "run_status": {
      "type": "string",
      "enum": [
        "running",
        "completed",
        "skipped",
        "failed",
        "cancelled",
        "timed_out",
        "abandoned"
      ]
    },
    "session_id": { "type": "string", "pattern": "^session_" },
    "thread_id": { "type": "string", "pattern": "^thread_" },
    "session": {
      "type": "object",
      "required": ["protocol_version", "session_id", "title"],
      "properties": {
        "protocol_version": { "const": "agent.v1" },
        "session_id": { "type": "string", "pattern": "^session_" },
        "title": { "type": "string" }
      },
      "additionalProperties": true
    },
    "thread": {
      "type": "object",
      "required": ["protocol_version", "thread_id", "session_id"],
      "properties": {
        "protocol_version": { "const": "agent.v1" },
        "thread_id": { "type": "string", "pattern": "^thread_" },
        "session_id": { "type": "string", "pattern": "^session_" }
      },
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["protocol_version", "step_id", "thread_id", "kind"],
        "properties": {
          "protocol_version": { "const": "agent.v1" },
          "step_id": { "type": "string", "pattern": "^step_" },
          "thread_id": { "type": "string", "pattern": "^thread_" },
          "kind": { "type": "string" },
          "run_id": { "type": "string", "pattern": "^run_" }
        },
        "additionalProperties": true
      }
    },
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "protocol_version",
          "proposal_id",
          "run_id",
          "agent_id",
          "kind",
          "summary",
          "status"
        ],
        "properties": {
          "protocol_version": { "const": "agent.v1" },
          "proposal_id": { "type": "string", "pattern": "^proposal_" },
          "run_id": { "type": "string", "pattern": "^run_" },
          "agent_id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "summary": { "type": "string" },
          "status": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
