{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/eval-case.schema.json",
  "title": "EvalCase",
  "type": "object",
  "required": ["id", "agent_id", "catalog", "expect"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "catalog": { "type": "string", "minLength": 1 },
    "golden_trace": { "type": "string", "minLength": 1 },
    "input": { "type": "object", "default": {} },
    "expect": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "running",
            "completed",
            "skipped",
            "failed",
            "cancelled",
            "timed_out",
            "abandoned"
          ]
        },
        "agent_id": { "type": "string", "minLength": 1 },
        "trace_events": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "tool_calls": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "proposals": {
          "type": "object",
          "properties": {
            "min_count": { "type": "integer", "minimum": 0 },
            "kinds": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "statuses": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "created",
                  "pending_approval",
                  "approved",
                  "denied",
                  "expired",
                  "applying",
                  "applied",
                  "apply_failed",
                  "undoing",
                  "undone",
                  "undo_failed"
                ]
              }
            }
          },
          "additionalProperties": false
        },
        "prompt_manifest": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "agent_version": { "type": "string", "minLength": 1 },
            "model_family": { "type": "string", "minLength": 1 },
            "provider": { "type": "string", "minLength": 1 },
            "model": { "type": "string", "minLength": 1 },
            "tool_schema_version": { "type": "string", "minLength": 1 },
            "block_hashes": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^blake3:[a-f0-9]{64}$"
              }
            }
          },
          "additionalProperties": false
        },
        "output_mode": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "scoring_hook": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "min_score": { "type": "number" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
