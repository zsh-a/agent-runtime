{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/interaction-envelope.schema.json",
  "title": "InteractionEnvelope",
  "type": "object",
  "required": [
    "protocol_version",
    "interaction_id",
    "kind",
    "mode",
    "status",
    "title",
    "response_schema",
    "payload",
    "metadata",
    "resume",
    "created_at"
  ],
  "properties": {
    "protocol_version": { "const": "agent.v1" },
    "interaction_id": { "type": "string", "minLength": 1 },
    "kind": { "enum": ["input", "choice", "approval"] },
    "mode": {
      "enum": ["one_tap", "confirm_diff", "typed"],
      "default": "one_tap"
    },
    "status": {
      "enum": ["pending", "resolved", "rejected", "cancelled", "expired"],
      "default": "pending"
    },
    "title": { "type": "string", "minLength": 1 },
    "prompt": { "type": "string", "default": "" },
    "options": {
      "type": "array",
      "items": { "$ref": "#/$defs/option" },
      "default": []
    },
    "confirmation": {
      "anyOf": [
        { "$ref": "#/$defs/confirmation" },
        { "type": "null" }
      ]
    },
    "subject": {
      "anyOf": [
        { "$ref": "#/$defs/subject" },
        { "type": "null" }
      ]
    },
    "response_schema": { "type": "object", "default": {} },
    "payload": { "type": "object", "default": {} },
    "metadata": { "type": "object", "default": {} },
    "resume": {
      "$ref": "#/$defs/resume",
      "default": { "kind": "chat_turn" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": ["string", "null"], "format": "date-time" },
    "response": {
      "anyOf": [
        { "$ref": "#/$defs/response" },
        { "type": "null" }
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "choice" } } },
      "then": {
        "properties": { "options": { "minItems": 2 } }
      },
      "else": {
        "properties": { "options": { "maxItems": 0 } }
      }
    },
    {
      "if": { "properties": { "mode": { "const": "typed" } } },
      "then": { "required": ["confirmation"] }
    },
    {
      "if": { "properties": { "status": { "const": "pending" } } },
      "then": { "not": { "required": ["response"] } },
      "else": {
        "if": { "properties": { "status": { "const": "expired" } } },
        "then": { "not": { "required": ["response"] } },
        "else": { "required": ["response"] }
      }
    }
  ],
  "$defs": {
    "option": {
      "type": "object",
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "default": "" },
        "metadata": { "type": "object", "default": {} }
      },
      "additionalProperties": false
    },
    "confirmation": {
      "type": "object",
      "required": ["required_text"],
      "properties": {
        "required_text": { "type": "string", "minLength": 1 },
        "case_sensitive": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },
    "subject": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "metadata": { "type": "object", "default": {} }
      },
      "additionalProperties": false
    },
    "resume": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": ["chat_turn", "proposal_apply", "host", "none"],
          "default": "chat_turn"
        },
        "token": { "type": ["string", "null"], "minLength": 1 }
      },
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "required": [
        "protocol_version",
        "interaction_id",
        "action",
        "value",
        "responded_at",
        "metadata"
      ],
      "properties": {
        "protocol_version": { "const": "agent.v1" },
        "interaction_id": { "type": "string", "minLength": 1 },
        "action": { "enum": ["submit", "approve", "reject", "cancel"] },
        "value": true,
        "confirmation_text": { "type": ["string", "null"] },
        "responded_by": { "type": ["string", "null"], "minLength": 1 },
        "responded_at": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object", "default": {} }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
