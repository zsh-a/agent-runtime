{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/prompt-manifest.schema.json",
  "title": "PromptManifest",
  "type": "object",
  "required": [
    "protocol_version",
    "id",
    "version",
    "agent_id",
    "agent_version",
    "catalog_version",
    "generated_at",
    "model_family",
    "provider",
    "model",
    "tool_schema_version",
    "active_domains",
    "blocks"
  ],
  "properties": {
    "protocol_version": { "const": "agent.v1" },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "agent_version": { "type": "string", "minLength": 1 },
    "catalog_version": { "const": "agent_catalog.v1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "model_family": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "tool_schema_version": { "type": "string", "minLength": 1 },
    "active_domains": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["index", "source", "content_hash", "text"],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "source": { "type": "string", "minLength": 1 },
          "content_hash": {
            "type": "string",
            "pattern": "^blake3:[a-f0-9]{64}$"
          },
          "text": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
