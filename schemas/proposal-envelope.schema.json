{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/proposal-envelope.schema.json",
  "title": "ProposalEnvelope",
  "type": "object",
  "required": [
    "protocol_version",
    "proposal_id",
    "run_id",
    "agent_id",
    "kind",
    "summary",
    "payload",
    "status",
    "created_at"
  ],
  "properties": {
    "protocol_version": { "const": "agent.v1" },
    "proposal_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "payload": { "type": "object" },
    "status": {
      "type": "string",
      "enum": [
        "created",
        "pending_approval",
        "approved",
        "denied",
        "expired",
        "applying",
        "applied",
        "apply_failed",
        "undoing",
        "undone",
        "undo_failed"
      ]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false
}
