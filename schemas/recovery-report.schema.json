{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/recovery-report.schema.json",
  "title": "RecoveryReport",
  "type": "object",
  "required": ["scanned_runs", "abandoned_count", "recovered_runs"],
  "properties": {
    "scanned_runs": { "type": "integer", "minimum": 0 },
    "abandoned_count": { "type": "integer", "minimum": 0 },
    "recovered_runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "run_id",
          "agent_id",
          "previous_status",
          "new_status",
          "started_at",
          "abandoned_at",
          "reason"
        ],
        "properties": {
          "run_id": { "type": "string", "pattern": "^run_" },
          "agent_id": { "type": "string", "minLength": 1 },
          "previous_status": { "const": "running" },
          "new_status": { "const": "abandoned" },
          "started_at": { "type": "string", "format": "date-time" },
          "abandoned_at": { "type": "string", "format": "date-time" },
          "reason": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
