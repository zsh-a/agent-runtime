{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/run-result.schema.json",
  "title": "RunResult",
  "type": "object",
  "required": [
    "protocol_version",
    "run_id",
    "agent_id",
    "status",
    "started_at",
    "finished_at"
  ],
  "properties": {
    "protocol_version": { "const": "agent.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["running", "completed", "skipped", "failed", "cancelled", "timed_out", "abandoned"]
    },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "summary": { "type": ["string", "null"] },
    "output": { "type": "object", "default": {} },
    "error": { "$ref": "#/$defs/error" }
  },
  "additionalProperties": false,
  "$defs": {
    "error": {
      "type": "object",
      "required": ["kind", "code", "message", "retryable"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "validation_error",
            "tool_error",
            "llm_error",
            "timeout",
            "cancelled",
            "approval_required",
            "transient_external_error",
            "internal_error"
          ]
        },
        "code": { "type": "string" },
        "message": { "type": "string" },
        "retryable": { "type": "boolean" },
        "details": { "type": "object", "default": {} }
      },
      "additionalProperties": false
    }
  }
}
