{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/run-result.schema.json",
  "title": "RunResult",
  "type": "object",
  "required": [
    "protocol_version",
    "run_id",
    "agent_id",
    "status",
    "started_at",
    "finished_at"
  ],
  "properties": {
    "protocol_version": { "const": "agent.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["running", "completed", "skipped", "failed", "cancelled", "timed_out", "abandoned"]
    },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "summary": { "type": ["string", "null"] },
    "output": { "type": "object", "default": {} },
    "error": { "$ref": "#/$defs/error" },
    "workflow": {
      "anyOf": [{ "$ref": "#/$defs/run_workflow" }, { "type": "null" }]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "run_workflow": {
      "type": "object",
      "properties": {
        "workflow_id": { "type": ["string", "null"], "minLength": 1 },
        "root_run_id": { "type": ["string", "null"], "minLength": 1 },
        "parent_run_id": { "type": ["string", "null"], "minLength": 1 },
        "parent_agent_id": { "type": ["string", "null"], "minLength": 1 },
        "dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/run_dependency" },
          "default": []
        },
        "fanout_id": { "type": ["string", "null"], "minLength": 1 },
        "fanin_id": { "type": ["string", "null"], "minLength": 1 },
        "compensation": {
          "anyOf": [{ "$ref": "#/$defs/run_compensation" }, { "type": "null" }]
        },
        "metadata": { "type": "object", "default": {} }
      },
      "additionalProperties": false
    },
    "run_dependency": {
      "type": "object",
      "required": ["run_id"],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "edge": { "type": ["string", "null"], "minLength": 1 },
        "metadata": { "type": "object", "default": {} }
      },
      "additionalProperties": false
    },
    "run_compensation": {
      "type": "object",
      "required": ["compensates_run_id"],
      "properties": {
        "compensates_run_id": { "type": "string", "minLength": 1 },
        "strategy": { "type": ["string", "null"], "minLength": 1 },
        "metadata": { "type": "object", "default": {} }
      },
      "additionalProperties": false
    },
    "error": {
      "type": "object",
      "required": ["kind", "code", "message", "retryable"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "validation_error",
            "tool_error",
            "llm_error",
            "timeout",
            "cancelled",
            "approval_required",
            "transient_external_error",
            "internal_error"
          ]
        },
        "code": { "type": "string" },
        "message": { "type": "string" },
        "retryable": { "type": "boolean" },
        "details": { "type": "object", "default": {} }
      },
      "additionalProperties": false
    }
  }
}
