{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/tool-source-manifest.schema.json",
  "title": "ToolSourceManifest",
  "type": "object",
  "required": ["sources"],
  "properties": {
    "version": { "const": "tool_source.v1" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "tools"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "protocol": {
            "type": "string",
            "enum": ["jsonl_tool_call", "mcp_stdio", "http_json"],
            "default": "jsonl_tool_call"
          },
          "command": { "type": "string", "minLength": 1 },
          "args": {
            "type": "array",
            "items": { "type": "string" }
          },
          "cwd": {
            "type": ["string", "null"],
            "minLength": 1,
            "description": "Optional working directory for process and MCP stdio sources."
          },
          "env": {
            "type": "object",
            "description": "Additional environment variables for process and MCP stdio sources. Values may reference environment variables with ${env:NAME}.",
            "additionalProperties": { "type": "string" }
          },
          "inherit_env": {
            "type": "boolean",
            "default": true,
            "description": "Whether process and MCP stdio sources inherit the runtime process environment."
          },
          "endpoint": {
            "type": "string",
            "format": "uri",
            "pattern": "^https?://"
          },
          "headers": {
            "type": "object",
            "description": "Static HTTP headers. Values may reference environment variables with ${env:NAME}.",
            "additionalProperties": { "type": "string" }
          },
          "timeout_ms": {
            "type": ["integer", "null"],
            "minimum": 1,
            "description": "Optional timeout applied to each tool call from this source."
          },
          "max_retries": {
            "type": "integer",
            "minimum": 0,
            "default": 0,
            "description": "Number of retries for retryable tool-source failures."
          },
          "retry_backoff_ms": {
            "type": ["integer", "null"],
            "minimum": 0,
            "description": "Delay between retry attempts for retryable failures."
          },
          "max_output_bytes": {
            "type": ["integer", "null"],
            "minimum": 1,
            "description": "Optional maximum serialized JSON output size accepted from each tool call."
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "description", "input_schema", "risk"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "input_schema": { "type": "object" },
                "output_schema": { "type": ["object", "null"] },
                "risk": {
                  "type": "string",
                  "enum": ["read_only", "low", "medium", "high"]
                },
                "metadata": { "type": "object" }
              },
              "additionalProperties": false
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "protocol": { "const": "http_json" } },
              "required": ["protocol"]
            },
            "then": { "required": ["endpoint"] },
            "else": { "required": ["command"] }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
