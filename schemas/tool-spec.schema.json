{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/tool-spec.schema.json",
  "title": "ToolSpec",
  "type": "object",
  "required": ["name", "description", "input_schema", "risk"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "input_schema": { "type": "object" },
    "output_schema": { "type": ["object", "null"] },
    "risk": {
      "type": "string",
      "enum": ["read_only", "low", "medium", "high"]
    },
    "replay_policy": {
      "type": "string",
      "enum": ["safe_retry", "idempotent", "at_most_once"],
      "default": "at_most_once"
    },
    "metadata": { "type": "object", "default": {} }
  },
  "additionalProperties": false
}
