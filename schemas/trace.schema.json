{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/trace.schema.json",
  "title": "AgentTrace",
  "type": "object",
  "required": [
    "protocol_version",
    "runtime_version",
    "run_id",
    "agent_id",
    "agent_version",
    "started_at",
    "finished_at",
    "events"
  ],
  "properties": {
    "protocol_version": { "const": "agent.v1" },
    "runtime_version": { "type": "string" },
    "run_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "agent_version": { "type": "string" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "input": { "type": "object", "default": {} },
    "output": { "type": "object", "default": {} },
    "artifact_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_ref" },
      "default": []
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "occurred_at"],
        "properties": {
          "kind": { "type": "string" },
          "occurred_at": { "type": "string", "format": "date-time" },
          "payload": { "type": "object", "default": {} }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": { "const": "agent_runtime_step" }
              },
              "required": ["kind"]
            },
            "then": {
              "required": ["payload"],
              "properties": {
                "payload": {
                  "type": "object",
                  "required": [
                    "run_id",
                    "agent_id",
                    "status",
                    "step_index",
                    "tool_name",
                    "run_state"
                  ],
                  "properties": {
                    "run_id": { "type": "string", "minLength": 1 },
                    "agent_id": { "type": "string", "minLength": 1 },
                    "status": {
                      "enum": [
                        "tool_call_requested",
                        "completed",
                        "failed",
                        "cancelled",
                        "policy_denied",
                        "closed_early",
                        "timed_out"
                      ]
                    },
                    "step_index": { "type": "integer", "minimum": 0 },
                    "tool_name": { "type": ["string", "null"], "minLength": 1 },
                    "run_state": {
                      "type": "object",
                      "required": [
                        "status",
                        "step_index",
                        "remaining_tool_count",
                        "tool_result_count",
                        "terminal_reason"
                      ],
                      "properties": {
                        "status": {
                          "enum": [
                            "tool_call_requested",
                            "completed",
                            "failed",
                            "cancelled",
                            "policy_denied",
                            "closed_early",
                            "timed_out"
                          ]
                        },
                        "step_index": { "type": ["integer", "null"], "minimum": 0 },
                        "remaining_tool_count": { "type": "integer", "minimum": 0 },
                        "tool_result_count": { "type": "integer", "minimum": 0 },
                        "terminal_reason": {
                          "enum": [
                            "done",
                            "stream_error",
                            "user_cancel",
                            "policy_denied",
                            "closed_early",
                            null
                          ]
                        }
                      },
                      "allOf": [
                        {
                          "if": {
                            "properties": { "status": { "const": "tool_call_requested" } },
                            "required": ["status"]
                          },
                          "then": {
                            "properties": { "terminal_reason": { "const": null } }
                          }
                        },
                        {
                          "if": {
                            "properties": { "status": { "const": "completed" } },
                            "required": ["status"]
                          },
                          "then": {
                            "properties": { "terminal_reason": { "const": "done" } }
                          }
                        },
                        {
                          "if": {
                            "properties": { "status": { "const": "failed" } },
                            "required": ["status"]
                          },
                          "then": {
                            "properties": { "terminal_reason": { "const": "stream_error" } }
                          }
                        },
                        {
                          "if": {
                            "properties": { "status": { "const": "cancelled" } },
                            "required": ["status"]
                          },
                          "then": {
                            "properties": { "terminal_reason": { "const": "user_cancel" } }
                          }
                        },
                        {
                          "if": {
                            "properties": { "status": { "const": "policy_denied" } },
                            "required": ["status"]
                          },
                          "then": {
                            "properties": { "terminal_reason": { "const": "policy_denied" } }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "status": { "enum": ["closed_early", "timed_out"] }
                            },
                            "required": ["status"]
                          },
                          "then": {
                            "properties": { "terminal_reason": { "const": "closed_early" } }
                          }
                        }
                      ],
                      "additionalProperties": true
                    }
                  },
                  "allOf": [
                    {
                      "if": {
                        "properties": { "status": { "const": "tool_call_requested" } },
                        "required": ["status"]
                      },
                      "then": {
                        "properties": {
                          "run_state": {
                            "properties": { "status": { "const": "tool_call_requested" } }
                          }
                        }
                      }
                    },
                    {
                      "if": {
                        "properties": { "status": { "const": "completed" } },
                        "required": ["status"]
                      },
                      "then": {
                        "properties": {
                          "run_state": {
                            "properties": { "status": { "const": "completed" } }
                          }
                        }
                      }
                    },
                    {
                      "if": {
                        "properties": { "status": { "const": "failed" } },
                        "required": ["status"]
                      },
                      "then": {
                        "properties": {
                          "run_state": {
                            "properties": { "status": { "const": "failed" } }
                          }
                        }
                      }
                    },
                    {
                      "if": {
                        "properties": { "status": { "const": "cancelled" } },
                        "required": ["status"]
                      },
                      "then": {
                        "properties": {
                          "run_state": {
                            "properties": { "status": { "const": "cancelled" } }
                          }
                        }
                      }
                    },
                    {
                      "if": {
                        "properties": { "status": { "const": "policy_denied" } },
                        "required": ["status"]
                      },
                      "then": {
                        "properties": {
                          "run_state": {
                            "properties": { "status": { "const": "policy_denied" } }
                          }
                        }
                      }
                    },
                    {
                      "if": {
                        "properties": { "status": { "const": "closed_early" } },
                        "required": ["status"]
                      },
                      "then": {
                        "properties": {
                          "run_state": {
                            "properties": { "status": { "const": "closed_early" } }
                          }
                        }
                      }
                    },
                    {
                      "if": {
                        "properties": { "status": { "const": "timed_out" } },
                        "required": ["status"]
                      },
                      "then": {
                        "properties": {
                          "run_state": {
                            "properties": { "status": { "const": "timed_out" } }
                          }
                        }
                      }
                    }
                  ],
                  "additionalProperties": true
                }
              }
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "artifact_ref": {
      "type": "object",
      "required": ["artifact_id", "uri"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "minLength": 1 },
        "media_type": { "type": ["string", "null"], "minLength": 1 },
        "size_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "metadata": { "type": "object", "default": {} }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
