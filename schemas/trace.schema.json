{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/schemas/trace.schema.json",
  "title": "AgentTrace",
  "type": "object",
  "required": [
    "protocol_version",
    "runtime_version",
    "run_id",
    "agent_id",
    "agent_version",
    "scope",
    "started_at",
    "finished_at",
    "events"
  ],
  "properties": {
    "protocol_version": { "const": "agent.v1" },
    "runtime_version": { "type": "string" },
    "run_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "agent_version": { "type": "string" },
    "scope": { "$ref": "#/$defs/run_scope" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "input": { "type": "object", "default": {} },
    "output": { "type": "object", "default": {} },
    "workflow": {
      "anyOf": [{ "$ref": "#/$defs/run_workflow" }, { "type": "null" }]
    },
    "usage_summary": {
      "anyOf": [{ "$ref": "#/$defs/trace_usage_summary" }, { "type": "null" }]
    },
    "artifact_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_ref" },
      "default": []
    },
    "spans": {
      "type": "array",
      "items": { "$ref": "#/$defs/trace_span" },
      "default": []
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "occurred_at"],
        "properties": {
          "kind": { "type": "string" },
          "occurred_at": { "type": "string", "format": "date-time" },
          "payload": { "type": "object", "default": {} }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": { "const": "agent_runtime_step" }
              },
              "required": ["kind"]
            },
            "then": {
              "required": ["payload"],
              "properties": {
                "payload": {
                  "type": "object",
                  "required": [
                    "run_id",
                    "agent_id",
                    "status",
                    "step_index",
                    "effect_id",
                    "effect_kind",
                    "tool_name",
                    "subagent_id",
                    "run_state"
                  ],
                  "properties": {
                    "run_id": { "type": "string", "minLength": 1 },
                    "agent_id": { "type": "string", "minLength": 1 },
                    "status": {
                      "enum": [
                        "effect_requested",
                        "completed",
                        "failed",
                        "cancelled",
                        "policy_denied",
                        "closed_early",
                        "timed_out"
                      ]
                    },
                    "step_index": { "type": "integer", "minimum": 0 },
                    "effect_id": { "type": ["string", "null"], "minLength": 1 },
                    "effect_kind": {
                      "enum": ["tool", "subagent", null]
                    },
                    "tool_name": { "type": ["string", "null"], "minLength": 1 },
                    "subagent_id": { "type": ["string", "null"], "minLength": 1 },
                    "run_state": {
                      "type": "object",
                      "required": [
                        "status",
                        "step_index",
                        "remaining_effect_count",
                        "effect_result_count",
                        "terminal_reason"
                      ],
                      "properties": {
                        "status": {
                          "enum": [
                            "effect_requested",
                            "completed",
                            "failed",
                            "cancelled",
                            "policy_denied",
                            "closed_early",
                            "timed_out"
                          ]
                        },
                        "step_index": { "type": ["integer", "null"], "minimum": 0 },
                        "remaining_effect_count": { "type": "integer", "minimum": 0 },
                        "effect_result_count": { "type": "integer", "minimum": 0 },
                        "terminal_reason": {
                          "enum": [
                            "done",
                            "stream_error",
                            "user_cancel",
                            "policy_denied",
                            "closed_early",
                            null
                          ]
                        }
                      },
                      "allOf": [
                        {
                          "if": {
                            "properties": {
                              "status": {
                                "const": "effect_requested"
                              }
                            },
                            "required": ["status"]
                          },
                          "then": {
                            "properties": { "terminal_reason": { "const": null } }
                          }
                        },
                        {
                          "if": {
                            "properties": { "status": { "const": "completed" } },
                            "required": ["status"]
                          },
                          "then": {
                            "properties": { "terminal_reason": { "const": "done" } }
                          }
                        },
                        {
                          "if": {
                            "properties": { "status": { "const": "failed" } },
                            "required": ["status"]
                          },
                          "then": {
                            "properties": { "terminal_reason": { "const": "stream_error" } }
                          }
                        },
                        {
                          "if": {
                            "properties": { "status": { "const": "cancelled" } },
                            "required": ["status"]
                          },
                          "then": {
                            "properties": { "terminal_reason": { "const": "user_cancel" } }
                          }
                        },
                        {
                          "if": {
                            "properties": { "status": { "const": "policy_denied" } },
                            "required": ["status"]
                          },
                          "then": {
                            "properties": { "terminal_reason": { "const": "policy_denied" } }
                          }
                        },
                        {
                          "if": {
                            "properties": {
                              "status": { "enum": ["closed_early", "timed_out"] }
                            },
                            "required": ["status"]
                          },
                          "then": {
                            "properties": { "terminal_reason": { "const": "closed_early" } }
                          }
                        }
                      ],
                      "additionalProperties": true
                    }
                  },
                  "allOf": [
                    {
                      "if": {
                        "properties": { "status": { "const": "effect_requested" } },
                        "required": ["status"]
                      },
                      "then": {
                        "properties": {
                          "run_state": {
                            "properties": { "status": { "const": "effect_requested" } }
                          }
                        }
                      }
                    },
                    {
                      "if": {
                        "properties": { "status": { "const": "completed" } },
                        "required": ["status"]
                      },
                      "then": {
                        "properties": {
                          "run_state": {
                            "properties": { "status": { "const": "completed" } }
                          }
                        }
                      }
                    },
                    {
                      "if": {
                        "properties": { "status": { "const": "failed" } },
                        "required": ["status"]
                      },
                      "then": {
                        "properties": {
                          "run_state": {
                            "properties": { "status": { "const": "failed" } }
                          }
                        }
                      }
                    },
                    {
                      "if": {
                        "properties": { "status": { "const": "cancelled" } },
                        "required": ["status"]
                      },
                      "then": {
                        "properties": {
                          "run_state": {
                            "properties": { "status": { "const": "cancelled" } }
                          }
                        }
                      }
                    },
                    {
                      "if": {
                        "properties": { "status": { "const": "policy_denied" } },
                        "required": ["status"]
                      },
                      "then": {
                        "properties": {
                          "run_state": {
                            "properties": { "status": { "const": "policy_denied" } }
                          }
                        }
                      }
                    },
                    {
                      "if": {
                        "properties": { "status": { "const": "closed_early" } },
                        "required": ["status"]
                      },
                      "then": {
                        "properties": {
                          "run_state": {
                            "properties": { "status": { "const": "closed_early" } }
                          }
                        }
                      }
                    },
                    {
                      "if": {
                        "properties": { "status": { "const": "timed_out" } },
                        "required": ["status"]
                      },
                      "then": {
                        "properties": {
                          "run_state": {
                            "properties": { "status": { "const": "timed_out" } }
                          }
                        }
                      }
                    }
                  ],
                  "additionalProperties": true
                }
              }
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "run_scope": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["global", "user", "tenant"] },
        "id": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "global" } } },
          "then": { "not": { "required": ["id"] } }
        },
        {
          "if": { "properties": { "type": { "enum": ["user", "tenant"] } } },
          "then": { "required": ["id"] }
        }
      ],
      "additionalProperties": false
    },
    "run_workflow": {
      "type": "object",
      "properties": {
        "workflow_id": { "type": ["string", "null"], "minLength": 1 },
        "root_run_id": { "type": ["string", "null"], "minLength": 1 },
        "parent_run_id": { "type": ["string", "null"], "minLength": 1 },
        "parent_agent_id": { "type": ["string", "null"], "minLength": 1 },
        "dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/run_dependency" },
          "default": []
        },
        "fanout_id": { "type": ["string", "null"], "minLength": 1 },
        "fanin_id": { "type": ["string", "null"], "minLength": 1 },
        "compensation": {
          "anyOf": [{ "$ref": "#/$defs/run_compensation" }, { "type": "null" }]
        },
        "metadata": { "type": "object", "default": {} }
      },
      "additionalProperties": false
    },
    "run_dependency": {
      "type": "object",
      "required": ["run_id"],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "edge": { "type": ["string", "null"], "minLength": 1 },
        "metadata": { "type": "object", "default": {} }
      },
      "additionalProperties": false
    },
    "run_compensation": {
      "type": "object",
      "required": ["compensates_run_id"],
      "properties": {
        "compensates_run_id": { "type": "string", "minLength": 1 },
        "strategy": { "type": ["string", "null"], "minLength": 1 },
        "metadata": { "type": "object", "default": {} }
      },
      "additionalProperties": false
    },
    "trace_span": {
      "type": "object",
      "required": [
        "span_id",
        "name",
        "started_at",
        "finished_at",
        "duration_ms",
        "status"
      ],
      "properties": {
        "span_id": { "type": "string", "minLength": 1 },
        "parent_span_id": { "type": ["string", "null"], "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "minLength": 1 },
        "attributes": {
          "type": "object",
          "default": {},
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "trace_usage_summary": {
      "type": "object",
      "required": [
        "llm_request_count",
        "input_tokens",
        "output_tokens",
        "total_tokens"
      ],
      "properties": {
        "llm_request_count": { "type": "integer", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "cost_micros_by_currency": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "by_provider": {
          "type": "array",
          "items": { "$ref": "#/$defs/trace_usage_provider_summary" },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "trace_usage_provider_summary": {
      "type": "object",
      "required": [
        "provider",
        "request_count",
        "input_tokens",
        "output_tokens",
        "total_tokens"
      ],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "model": { "type": ["string", "null"], "minLength": 1 },
        "request_count": { "type": "integer", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "cost_micros_by_currency": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      },
      "additionalProperties": false
    },
    "artifact_ref": {
      "type": "object",
      "required": ["artifact_id", "uri"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": ["blob", "document", "image", "dataset", "log", "other"],
          "default": "blob"
        },
        "uri": { "type": "string", "minLength": 1 },
        "media_type": { "type": ["string", "null"], "minLength": 1 },
        "size_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "redaction_classification": {
          "enum": ["public", "internal", "confidential", "secret"],
          "default": "internal"
        },
        "store": {
          "anyOf": [{ "$ref": "#/$defs/artifact_store_ref" }, { "type": "null" }]
        },
        "metadata": { "type": "object", "default": {} }
      },
      "additionalProperties": false
    },
    "artifact_store_ref": {
      "type": "object",
      "required": ["provider"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "bucket": { "type": ["string", "null"], "minLength": 1 },
        "key": { "type": ["string", "null"], "minLength": 1 },
        "version": { "type": ["string", "null"], "minLength": 1 },
        "metadata": { "type": "object", "default": {} }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
